# GridStack OS — Control Service Configuration
# Copy to .env and fill in your values.

# ── Site Parameters ──────────────────────────────────────────────────────────
GRIDSTACK_ISO=ERCOT
GRIDSTACK_BREAK_EVEN_MWH=85.0
GRIDSTACK_BESS_POWER_MW=1.9
GRIDSTACK_BESS_ENERGY_MWH=3.8
GRIDSTACK_MINING_POWER_MW=15.0
GRIDSTACK_INTERCONNECTION_MW=100.0
GRIDSTACK_RTE=0.92
GRIDSTACK_GRID_TIED=true
GRIDSTACK_ANCILLARY_PREMIUM=12.0
GRIDSTACK_DISPATCH_INTERVAL_SECONDS=300

# ── API Keys ─────────────────────────────────────────────────────────────────
GRIDSTACK_GRIDSTATUS_API_KEY=your_gridstatus_key_here

# ── Foreman Mining ───────────────────────────────────────────────────────────
GRIDSTACK_FOREMAN_API_URL=https://dashboard.foreman.mn/api
GRIDSTACK_FOREMAN_CLIENT_ID=your_client_id
GRIDSTACK_FOREMAN_API_KEY=your_foreman_api_key

# ── BESS Adapter ─────────────────────────────────────────────────────────────
# Type: "rest" or "mqtt"
GRIDSTACK_BESS_ADAPTER_TYPE=rest

# REST adapter settings
GRIDSTACK_BESS_REST_URL=http://192.168.1.100:8080
GRIDSTACK_BESS_REST_API_KEY=

# MQTT adapter settings (used when BESS_ADAPTER_TYPE=mqtt)
GRIDSTACK_BESS_MQTT_BROKER=192.168.1.100
GRIDSTACK_BESS_MQTT_PORT=1883
GRIDSTACK_BESS_MQTT_USERNAME=
GRIDSTACK_BESS_MQTT_PASSWORD=
GRIDSTACK_BESS_MQTT_COMMAND_TOPIC=bess/command
GRIDSTACK_BESS_MQTT_STATUS_TOPIC=bess/status

# ── Safety ───────────────────────────────────────────────────────────────────
GRIDSTACK_SAFETY_MAX_CONSECUTIVE_FAILURES=3
GRIDSTACK_SAFETY_FAILSAFE_MINER_MODE=sleep
GRIDSTACK_SAFETY_FAILSAFE_BESS_MODE=idle
GRIDSTACK_SAFETY_MIN_SOC_PCT=5.0
GRIDSTACK_SAFETY_MAX_SOC_PCT=98.0

# ── Service ──────────────────────────────────────────────────────────────────
GRIDSTACK_SERVICE_PORT=8400
GRIDSTACK_AUDIT_DB_PATH=audit.db
